generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkType {
  REALIZADO
  DISPONIVEL
}

model Image {
  id        String   @id @default(cuid())
  url       String
  publicId  String   @unique
  title     String
  category  String
  type      WorkType @default(REALIZADO)
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}
